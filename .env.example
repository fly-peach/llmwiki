# === API (.env in api/) — local mode ===
STAGE=dev
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Optional: higher-quality PDF OCR (tables / complex layouts)
MISTRAL_API_KEY=
PDF_BACKEND=opendataloader   # "opendataloader" or "mistral"

