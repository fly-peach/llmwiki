# LLM Wiki Configuration
# Copy this file to .env and modify as needed

# === Server Ports ===
# API Server Port (default: 8000)
API_PORT=8000

# Web Server Port (default: 3000)
WEB_PORT=3000

# === Optional: PDF OCR ===
# Higher-quality PDF OCR for tables / complex layouts
# MISTRAL_API_KEY=your_mistral_api_key_here
# PDF_BACKEND=opendataloader   # "opendataloader" or "mistral"

# === Legacy Settings (for reference) ===
# These are now automatically derived from API_PORT and WEB_PORT
# STAGE=dev
# APP_URL=http://localhost:3000
# API_URL=http://localhost:8000
# NEXT_PUBLIC_API_URL=http://localhost:8000
